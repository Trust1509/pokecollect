# Docker Compose Projektname (bestimmt Container-Namen)
COMPOSE_PROJECT_NAME=pokecollect

# Datenbank
POSTGRES_USER=pokecollect
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=pokecollect
DATABASE_URL=postgresql://pokecollect:change_me_in_production@db:5432/pokecollect

# Cache
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=generate_a_long_random_string_here

# Cardmarket API (OAuth 1.0a)
# Registrierung: https://api.cardmarket.com
CARDMARKET_APP_TOKEN=
CARDMARKET_APP_SECRET=
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_ACCESS_SECRET=

# PokémonTCG.io (kostenlos)
# Registrierung: https://pokemontcg.io
POKEMONTCG_API_KEY=

# Notion (nur für einmalige Migration, danach entfernen)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Frontend
API_URL=http://api:8000
