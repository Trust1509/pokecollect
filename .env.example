# Docker Compose Projektname (bestimmt Container-Namen)
COMPOSE_PROJECT_NAME=pokecollect

# Datenbank
POSTGRES_USER=pokecollect
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=pokecollect
DATABASE_URL=postgresql://pokecollect:change_me_in_production@db:5432/pokecollect

# Auth (Single-User)
JWT_SECRET=generate_a_long_random_string_here
APP_USERNAME=admin
# bcrypt-Hash, Generierung siehe deploy/README.md
APP_PASSWORD_HASH=

# Frontend: URL, unter der der BROWSER die API erreicht (Build-Zeit-Variable!
# Nach Änderung muss das Web-Image neu gebaut werden.)
NEXT_PUBLIC_API_URL=http://192.168.x.x:3010

# TCGdex – zentrale Datenquelle (Karten, Bilder, Preise).
# Kostenlos, OHNE API-Key. Keine Variable nötig.

# Google Gemini – optional, aktiviert die starke Scan-Variante (Bilderkennung).
# Leer = Scan nutzt die lokale OCR. Auch über die Einstellungs-Seite pflegbar.
GEMINI_API_KEY=

# Cardmarket API (OAuth 1.0a) – NUR optionaler Preis-Fallback.
# Leer lassen, wenn nur TCGdex genutzt wird.
CARDMARKET_APP_TOKEN=
CARDMARKET_APP_SECRET=
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_ACCESS_SECRET=

# PokémonTCG.io – Legacy, nicht mehr für Bilder/Preise nötig.
