# Docker Compose Projektname (bestimmt Container-Namen)
COMPOSE_PROJECT_NAME=pokecollect

# Datenbank
POSTGRES_USER=pokecollect
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=pokecollect
DATABASE_URL=postgresql://pokecollect:change_me_in_production@db:5432/pokecollect

# Auth (Single-User)
JWT_SECRET=generate_a_long_random_string_here
APP_USERNAME=admin
# PFLICHT: bcrypt-Hash des Login-Passworts — ohne ihn verweigert die API den
# Start (kein eingebautes Default-Passwort mehr, Issue #1). Erzeugen mit:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'DEIN_PASSWORT', bcrypt.gensalt()).decode())"
# oder ohne lokales Python via Docker:
#   docker run --rm python:3.12-slim sh -c "pip -q install bcrypt==4.0.1 && python -c \"import bcrypt; print(bcrypt.hashpw(b'DEIN_PASSWORT', bcrypt.gensalt()).decode())\""
# ⚠️ WICHTIG: Wird diese .env von Docker Compose fürs Interpolieren genutzt
# (Standard-Setup: environment-Zeile APP_PASSWORD_HASH=${APP_PASSWORD_HASH}),
# muss JEDES $ im Hash als $$ escaped werden — sonst frisst Compose den
# Hash-Teil als "Variable" ($2b$12$Xyz → $$2b$$12$$Xyz). Erkennbar an
# WARN "The Xyz variable is not set" beim Start; Login schlägt dann fehl.
APP_PASSWORD_HASH=

# Frontend: URL, unter der der BROWSER die API erreicht (Build-Zeit-Variable!
# Nach Änderung muss das Web-Image neu gebaut werden.)
NEXT_PUBLIC_API_URL=http://192.168.x.x:3010

# Erlaubte Browser-Origins für die API, kommagetrennt (kein "*" mehr).
# Leer = Default http://localhost:3011,http://localhost:3021 (Prod-Web lokal
# + Teststand). Auf dem Server die echte Web-URL eintragen, z.B.:
# CORS_ORIGINS=http://<server-ip>:3011
CORS_ORIGINS=

# TCGdex – zentrale Datenquelle (Karten, Bilder, Preise).
# Kostenlos, OHNE API-Key. Keine Variable nötig.

# Google Gemini – optional, aktiviert die starke Scan-Variante (Bilderkennung).
# Leer = Scan nutzt die lokale OCR. Auch über die Einstellungs-Seite pflegbar.
GEMINI_API_KEY=

# Cardmarket API (OAuth 1.0a) – NUR optionaler Preis-Fallback.
# Leer lassen, wenn nur TCGdex genutzt wird.
CARDMARKET_APP_TOKEN=
CARDMARKET_APP_SECRET=
CARDMARKET_ACCESS_TOKEN=
CARDMARKET_ACCESS_SECRET=

# PokémonTCG.io – Legacy, nicht mehr für Bilder/Preise nötig.
